SELECT ROUND(SUM(Revenue),2) AS Total_Revenue
FROM ecommerce_data; 

SELECT COUNT(DISTINCT InvoiceNo) AS Total_Orders
FROM ecommerce_data;

SELECT COUNT(DISTINCT CustomerID) AS Total_Customers
FROM ecommerce_data;

SELECT CustomerID,
ROUND(SUM(Revenue),2) AS Total_Revenue
FROM ecommerce_data
GROUP BY CustomerID
ORDER BY Total_Revenue DESC
LIMIT 10;

SELECT Description,
ROUND(SUM(Revenue),2) AS Total_Revenue
FROM ecommerce_data
GROUP BY Description
ORDER BY Total_Revenue DESC
LIMIT 10;

SELECT Country,
ROUND(SUM(Revenue),2) AS Total_Revenue
FROM ecommerce_data
GROUP BY Country
ORDER BY Total_Revenue DESC
LIMIT 10;

SELECT ROUND(
SUM(Revenue) / COUNT(DISTINCT InvoiceNo),2
) AS Avg_Order_Value
FROM ecommerce_data;

SELECT Month,
ROUND(SUM(Revenue),2) AS Revenue
FROM ecommerce_data
GROUP BY Month
ORDER BY Month;
